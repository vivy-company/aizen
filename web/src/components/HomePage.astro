      </div>

      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-500" data-i18n="footer.resourcesTitle">{translations.en.footer.resourcesTitle}</p>
        <nav class="mt-5 grid gap-3 text-sm text-slate-700 dark:text-slate-300">
          <a href={SITE.githubUrl} target="_blank" rel="noopener noreferrer" class="transition hover:text-slate-950 dark:hover:text-white" data-i18n="footer.github">
            {translations.en.footer.github}
          </a>
          <a href={SITE.discordUrl} target="_blank" rel="noopener noreferrer" class="transition hover:text-slate-950 dark:hover:text-white" data-i18n="footer.discord">
            {translations.en.footer.discord}
          </a>
          <a href={SITE.twitterUrl} target="_blank" rel="noopener noreferrer" class="transition hover:text-slate-950 dark:hover:text-white" data-i18n="footer.twitter">
