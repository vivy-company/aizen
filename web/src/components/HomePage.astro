</main>

<script is:inline define:vars={{ themeStorageKey: SITE.themeStorageKey, stripeMonthly: SITE.stripeMonthly, stripeYearly: SITE.stripeYearly }}>
  const showcaseImages = document.querySelectorAll("[data-showcase]");
  const showcaseButtons = document.querySelectorAll("[data-showcase-btn]");
  const themeToggle = document.querySelector("[data-theme-toggle]");
  const billingButtons = document.querySelectorAll("[data-billing]");
  const proPrice = document.querySelector("[data-pro-price]");
  const proPeriod = document.querySelector("[data-pro-period]");
  const proSave = document.querySelector("[data-pro-save]");
  const proCta = document.querySelector("[data-pro-cta]");
  const proCtaText = document.querySelector("[data-pro-cta-text]");

  const applyShowcase = (tab) => {
    showcaseImages.forEach((node) => {
      const active = node.dataset.showcase === tab;
      node.dataset.showcaseActive = active ? "true" : "false";
      node.classList.toggle("pointer-events-none", !active);
      node.classList.toggle("pointer-events-auto", active);
    });

    showcaseButtons.forEach((button) => {
      const active = button.dataset.showcaseBtn === tab;
      button.dataset.showcaseBtnActive = active ? "true" : "false";
      button.setAttribute("aria-pressed", active ? "true" : "false");
      button.className = active
        ? "inline-flex items-center justify-center gap-2 rounded-full bg-slate-950 px-4 py-2 text-sm font-semibold text-white transition dark:bg-white dark:text-slate-950"
        : "inline-flex items-center justify-center gap-2 rounded-full px-4 py-2 text-sm font-semibold text-slate-600 transition hover:text-slate-950 dark:text-slate-300 dark:hover:text-white";
    });
  };

  showcaseButtons.forEach((button) => {
    button.addEventListener("click", () => {
      applyShowcase(button.dataset.showcaseBtn);
    });
  });

  const activeBtn = "flex-1 rounded-full bg-slate-950 py-2 px-4 text-sm font-medium text-white transition dark:bg-white dark:text-slate-950";
  const inactiveBtn = "flex-1 rounded-full py-2 px-4 text-sm font-medium text-slate-500 transition hover:text-slate-950 dark:text-slate-400 dark:hover:text-white";

  const applyBilling = (cycle) => {
    billingButtons.forEach((btn) => {
      btn.className = btn.dataset.billing === cycle ? activeBtn : inactiveBtn;
    });
    if (cycle === "yearly") {
      proPrice.textContent = "$59";
      proPeriod.textContent = "/yr";
      proSave.textContent = "Save 20%";
      proCta.href = stripeYearly;
      proCtaText.textContent = "Subscribe yearly";
    } else {
      proPrice.textContent = "$5.99";
      proPeriod.textContent = "/mo";
      proSave.textContent = "";
      proCta.href = stripeMonthly;
      proCtaText.textContent = "Subscribe monthly";
    }
  };

  billingButtons.forEach((btn) => {
    btn.addEventListener("click", () => applyBilling(btn.dataset.billing));
  });

  if (themeToggle) {
    themeToggle.addEventListener("click", () => {
      const isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem(themeStorageKey, isDark ? "dark" : "light");
    });
  }

  // Fetch latest version from Sparkle appcast and update download links
  (async () => {
    try {
      const res = await fetch("https://r2.aizen.win/appcast.xml");
      const xml = new DOMParser().parseFromString(await res.text(), "text/xml");
      const items = xml.querySelectorAll("channel > item");
      let best = null;
      for (const item of items) {
        const enc = item.querySelector("enclosure");
        if (!enc) continue;
        const url = (enc.getAttribute("url") || "").trim();
        if (!url) continue;
        const ver = (enc.getAttribute("sparkle:shortVersionString") || enc.getAttribute("sparkle:version") || "").trim();
        if (!best || ver.localeCompare(best.ver, undefined, { numeric: true }) > 0) {
          best = { ver, url };
        }
      }
      if (best) {
        document.querySelectorAll("[data-download]").forEach((a) => { a.href = best.url; });
      }
    } catch (_) {}
  })();
</script>
