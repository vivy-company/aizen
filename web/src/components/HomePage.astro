          <a href="/privacy" class="transition hover:text-slate-950 dark:hover:text-white" data-i18n="footer.privacy">{translations.en.footer.privacy}</a>
          <a href="/terms" class="transition hover:text-slate-950 dark:hover:text-white" data-i18n="footer.terms">{translations.en.footer.terms}</a>
          <a href="/refund" class="transition hover:text-slate-950 dark:hover:text-white" data-i18n="footer.refunds">{translations.en.footer.refunds}</a>
